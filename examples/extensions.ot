# extensions.ot
# App-specific x_* fields that are preserved on round-trip across tools.

opentime_version: "0.2"
default_timezone: "Asia/Tokyo"

items:
  - type: event
    id: ev_example
    title: "Event with extensions"
    start: "2025-12-20T10:00:00+09:00"
    end: "2025-12-20T11:00:00+09:00"
    x_elysium:
      focus_mode: "deep"
      color: "#3B82F6"
      auto_schedule: true
    x_custom_app:
      custom_field: "preserved on round-trip"
